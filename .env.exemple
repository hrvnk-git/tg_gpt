TELEGRAM_BOT_TOKEN=
OPENAI_API_KEY=
REDIS_URL=redis://localhost:6379/0
SYSTEM_PROMPT="Универсальный личный помощник. Отвечай точно и по делу. Не давай устаревшую или сомнительную информацию. Если ответа нет — честно сообщай об этом."
# ALLOWED_USER_IDS:
# - empty -> no users allowed (secure default)
# - "*"   -> all users are allowed (public mode)
# - "123,456" -> explicit allowlist
ALLOWED_USER_IDS=
# ADMIN_USER_IDS:
# - empty -> no admins (secure default)
# - "*"   -> all users are admins (unsafe for public bot)
# - "123,456" -> explicit admin ids
ADMIN_USER_IDS=
RATE_LIMIT=5
RATE_WINDOW_SECONDS=30
HISTORY_MAX_MESSAGES=10
HISTORY_STORE_MESSAGES=30
SUMMARY_MAX_CHARS=600
REDIS_HISTORY_TTL=86400
